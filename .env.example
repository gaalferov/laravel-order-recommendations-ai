APP_NAME="Order Recommendations"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

DB_CONNECTION=sqlite

MAIL_MAILER=mailtrap-sdk
MAILTRAP_HOST=send.api.mailtrap.io
MAILTRAP_API_KEY=your_mailtrap_api_key
# Set MAILTRAP_SANDBOX=true plus MAILTRAP_INBOX_ID to capture mail in a sandbox inbox during testing
MAILTRAP_SANDBOX=false
# MAILTRAP_INBOX_ID=
MAIL_FROM_ADDRESS=orders@yourdomain.com
MAIL_FROM_NAME="${APP_NAME}"
# Fallback recipient when Stripe session has no customer email (useful for `stripe trigger`)
MAIL_ORDER_RECIPIENT=customer@example.com
# Mailtrap category used to tag outgoing emails for analytics
MAILTRAP_CATEGORY="Order Confirmation"

STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret

OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o-mini
# Number of products to recommend in each email (1-5 recommended)
RECOMMENDATIONS_COUNT=3

CACHE_STORE=file
